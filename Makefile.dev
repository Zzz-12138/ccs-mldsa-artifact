CXX = g++
NVCC = nvcc

CXXFLAGS = -O3 -fopenmp -march=native -std=c++17
NVCCFLAGS = -O3 -Xcompiler -fopenmp -arch=sm_86 -std=c++17

# V5 supports multiple CUDA architectures for artifact portability.
NVCCFLAGS_V5 = -O3 -Xcompiler -fopenmp -std=c++17 \
	-gencode arch=compute_75,code=sm_75 \
	-gencode arch=compute_80,code=sm_80 \
	-gencode arch=compute_86,code=sm_86 \
	-gencode arch=compute_89,code=sm_89 \
	-gencode arch=compute_90,code=sm_90 \
	-gencode arch=compute_86,code=compute_86

# [UPDATED] Removed -ltbb because V3 uses O(1) Top-5 insertion, eliminating CPU memory/sorting bottlenecks.
LDFLAGS = -L/usr/local/cuda/lib64 -lcudart -lcublas -fopenmp -lstdc++fs

# Define targets and their respective object files
# TARGET1 = attacker_cuda_masked
# OBJS1 = main_masked_clean.o cpa_gpu_masked.o

TARGET2 = fusion_v3
OBJS2 = main_masked_fusion_v3.o cpa_gpu_masked_fusion_v3.o

TARGET3 = fusion_v4
OBJS3 = main_masked_fusion_v4.o cpa_gpu_masked_fusion_v4.o

# [NEW] Unmasked Version
TARGET4 = fusion_unmask_v0
OBJS4 = main_fusion_unmask_v0.o cpa_gpu_fusion_unmask_v0.o

# [NEW] Masked V5: verified V3 baseline + optional gated INTT source
TARGET5 = fusion_v5
OBJS5 = main_masked_fusion_v5.o cpa_gpu_masked_fusion_v5.o

# Default rule to build all active versions
all: $(TARGET2) $(TARGET3) $(TARGET4) $(TARGET5)

# ==============================================================================
# PREVIOUS CLEAN VERSION (STANDALONE) - COMMENTED OUT
# ==============================================================================
# $(TARGET1): $(OBJS1)
#	$(CXX) $(CXXFLAGS) $(OBJS1) -o $(TARGET1) $(LDFLAGS)
# main_masked_clean.o: main_masked_clean.cpp
#	$(CXX) $(CXXFLAGS) -c main_masked_clean.cpp -o main_masked_clean.o
# cpa_gpu_masked.o: cpa_gpu_masked.cu
#	$(NVCC) $(NVCCFLAGS) -c cpa_gpu_masked.cu -o cpa_gpu_masked.o

# ==============================================================================
# FUSION V3 VERSION (2-WAY FUSION: MASKED)
# ==============================================================================
$(TARGET2): $(OBJS2)
	$(CXX) $(CXXFLAGS) $(OBJS2) -o $(TARGET2) $(LDFLAGS)

main_masked_fusion_v3.o: main_masked_fusion_v3.cpp
	$(CXX) $(CXXFLAGS) -c main_masked_fusion_v3.cpp -o main_masked_fusion_v3.o

cpa_gpu_masked_fusion_v3.o: cpa_gpu_masked_fusion_v3.cu
	$(NVCC) $(NVCCFLAGS) -c cpa_gpu_masked_fusion_v3.cu -o cpa_gpu_masked_fusion_v3.o

# ==============================================================================
# NEW FUSION V4 VERSION (3-WAY FUSION: AY + CS1 + INTT_CS1 : MASKED)
# ==============================================================================
$(TARGET3): $(OBJS3)
	$(CXX) $(CXXFLAGS) $(OBJS3) -o $(TARGET3) $(LDFLAGS)

main_masked_fusion_v4.o: main_masked_fusion_v4.cpp
	$(CXX) $(CXXFLAGS) -c main_masked_fusion_v4.cpp -o main_masked_fusion_v4.o

cpa_gpu_masked_fusion_v4.o: cpa_gpu_masked_fusion_v4.cu
	$(NVCC) $(NVCCFLAGS) -c cpa_gpu_masked_fusion_v4.cu -o cpa_gpu_masked_fusion_v4.o

# ==============================================================================
# FUSION V5 VERSION (MASKED, V3 BASELINE + OPTIONAL GATED INTT)
# ==============================================================================
$(TARGET5): $(OBJS5)
	$(CXX) $(CXXFLAGS) $(OBJS5) -o $(TARGET5) $(LDFLAGS)

main_masked_fusion_v5.o: main_masked_fusion_v5.cpp
	$(CXX) $(CXXFLAGS) -c main_masked_fusion_v5.cpp -o main_masked_fusion_v5.o

cpa_gpu_masked_fusion_v5.o: cpa_gpu_masked_fusion_v5.cu
	$(NVCC) $(NVCCFLAGS_V5) -c cpa_gpu_masked_fusion_v5.cu -o cpa_gpu_masked_fusion_v5.o

# ==============================================================================
# NEW UNMASKED VERSION (FUSION V0)
# ==============================================================================
$(TARGET4): $(OBJS4)
	$(CXX) $(CXXFLAGS) $(OBJS4) -o $(TARGET4) $(LDFLAGS)

main_fusion_unmask_v0.o: main_fusion_unmask_v0.cpp
	$(CXX) $(CXXFLAGS) -c main_fusion_unmask_v0.cpp -o main_fusion_unmask_v0.o

cpa_gpu_fusion_unmask_v0.o: cpa_gpu_fusion_unmask_v0.cu
	$(NVCC) $(NVCCFLAGS) -c cpa_gpu_fusion_unmask_v0.cu -o cpa_gpu_fusion_unmask_v0.o

# Clean rule targeting all generated files
clean:
	rm -f *.o $(TARGET1) $(TARGET2) $(TARGET3) $(TARGET4) $(TARGET5) fusion_v2 fusion_attacker
